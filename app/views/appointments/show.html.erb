<div class="card shadow-sm p-4">
  <h2>Appointment Details</h2>
  <hr>
  <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") %></p>
  <p><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %></p> <p><strong>Vet:</strong> <%= link_to @appointment.vet.first_name, vet_path(@appointment.vet) %></p> <p><strong>Reason:</strong> <%= @appointment.reason %></p>
  <p><strong>Status:</strong> <span class="badge bg-secondary"><%= @appointment.status_text %></span></p>

  <h3 class="mt-4">Treatments</h3> <table class="table mt-2">
    <thead>
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Administered At</th>
      </tr>
    </thead>
    <tbody>
      <% @appointment.treatments.each do |t| %>
        <tr>
          <td><%= t.name %></td>
          <td><%= t.medication %></td>
          <td><%= t.dosage %></td>
          <td><%= t.administered_at.strftime("%I:%M %p") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
