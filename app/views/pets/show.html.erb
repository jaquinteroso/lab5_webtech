<div class="card shadow-sm p-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><%= @pet.name %></h2>
    <%= link_to 'Back to Pets', pets_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>
  <hr>
  <p><strong>Species:</strong> <%= @pet.species %></p>
  <p><strong>Breed:</strong> <%= @pet.breed %></p>
  <p><strong>Weight:</strong> <%= @pet.weight %> kg</p>
  <p><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") %></p> <p><strong>Owner:</strong> <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %></p> <h3 class="mt-4">Appointment History</h3>
  <table class="table table-sm mt-2">
    <thead class="table-light">
      <tr>
        <th>Date</th>
        <th>Reason</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @pet.appointments.each do |app| %>
        <tr>
          <td><%= app.date.strftime("%B %d, %Y") %></td>
          <td><%= app.reason %></td>
          <td><%= app.status_text %></td> <td><%= link_to "Details", appointment_path(app), class: "btn btn-link btn-sm p-0" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
