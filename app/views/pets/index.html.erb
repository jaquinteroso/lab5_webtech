<h1 class="mb-4">Pets</h1>
<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner</th>
      <th>DOB</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= pet.name %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= pet.owner.first_name %> <%= pet.owner.last_name %></td> <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td> <td><%= link_to "Show", pet_path(pet), class: "btn btn-sm btn-info" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
