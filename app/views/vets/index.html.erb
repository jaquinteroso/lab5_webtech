<h1 class="mb-4">Veterinarians</h1>

<table class="table table-striped table-hover shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Specialization</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= "#{vet.first_name} #{vet.last_name}" %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
        <td>
          <%# Link a la página de detalle del veterinario %>
          <%= link_to "View Profile", vet_path(vet), class: "btn btn-sm btn-outline-primary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
